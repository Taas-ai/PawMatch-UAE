# ─── Supabase PostgreSQL ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# ─── Firebase ────────────────────────────────────────────────────────────────
# Server (firebase-admin uses Application Default Credentials in Functions)
# For local dev: set GOOGLE_APPLICATION_CREDENTIALS to a service account JSON path
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001,capacitor://localhost

# ─── Web (Vite) ──────────────────────────────────────────────────────────────
# Get these from: Firebase Console → Project Settings → Your apps → Web app
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=pawmatch-uae.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=pawmatch-uae
VITE_FIREBASE_STORAGE_BUCKET=pawmatch-uae.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# ─── Google AI (Gemini) ──────────────────────────────────────────────────────
# Required until Phase 4: genkit.ts uses @genkit-ai/google-genai directly.
# Get from: https://aistudio.google.com/app/apikey
# TODO Phase 4: swap to @genkit-ai/vertexai → billed through Firebase, no key needed
GOOGLE_GENAI_API_KEY=your-google-ai-api-key

# ─── Removed ─────────────────────────────────────────────────────────────────
# JWT_SECRET  → replaced by Firebase Auth token verification
